{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Docket",
    "version": "2.0.4",
    "identifier": "com.docket-todo",
    "build": {
        "beforeDevCommand": "yarn dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "yarn build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Docket",
                "decorations": false,
                "resizable": true
            }
        ],
        "security": {
            "csp": null,
            "capabilities": [
                "default",
                "desktop"
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "createUpdaterArtifacts": true
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5OTRFMzgzNUFCMUUyRkIKUldUNzRyRmFnK09VU2ErNm1VeXpaL2FLeHFWU3ZiRFJvcWZTUjAzSXU5MElUYUJJQ0hWM2VhQU4K",
            "endpoints": [
                "https://github.com/bennettbijumathew/docket-todo/releases/latest/download/latest.json"
            ],
            "windows": {
                "dangerousInsecureTransportProtocol": false,
                "installMode": "passive"
            }
        }
    }
}